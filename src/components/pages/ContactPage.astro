---
import BaseLayout from '../BaseLayout.astro';
import type { Locale } from '../../lib/data';
import { i18n, site } from '../../lib/data';
import { contactPath, otherLocale } from '../../lib/paths';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = i18n[locale];

const altLocale = otherLocale(locale);
const pathname = contactPath(locale);
const altPathname = contactPath(altLocale);
const title = `${t.contact.title} - ${site.name}`;
const description = t.contact.lead;
const telHref = `tel:${site.phone.replace(/[^\d+]/g, '')}`;
const hoursLines = (t.contact.hoursValue as string).split('\n');
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  pathname={pathname}
  altPathname={altPathname}
>
  <main id="main">
    <section class="page-hero">
      <div class="container">
        <h1>{t.contact.title}</h1>
        <p class="lead">{t.contact.lead}</p>
      </div>
    </section>
    <section>
      <div class="container contact-grid">
        <div class="contact-info">
          <div class="item">
            <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><h4>{t.contact.address}</h4><p>{site.address[locale]}</p></div>
          </div>
          <div class="item">
            <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><h4>{t.contact.phone}</h4><p><a href={telHref}>{site.phone}</a></p></div>
          </div>
          <div class="item">
            <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><h4>{t.contact.email}</h4><p><a href={`mailto:${site.email}`}>{site.email}</a></p></div>
          </div>
          <div class="item">
            <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg></div>
            <div><h4>{t.contact.hours}</h4><p>{hoursLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</p></div>
          </div>
        </div>
        <div class="contact-form">
          <h3 style="font-family:var(--font-sans);font-size:1.25rem;margin-bottom:1rem">{t.contact.formTitle}</h3>
          <form id="contact-form" novalidate>
            <div class="form-row two">
              <div class="field"><label for="cf-name">{t.contact.name} *</label><input id="cf-name" name="name" required placeholder={t.contact.namePlaceholder} /></div>
              <div class="field"><label for="cf-email">{t.contact.email} *</label><input id="cf-email" name="email" type="email" required placeholder={t.contact.emailPlaceholder} /></div>
            </div>
            <div class="form-row">
              <div class="field"><label for="cf-phone">{t.contact.phone}</label><input id="cf-phone" name="phone" type="tel" placeholder={t.contact.phonePlaceholder} /></div>
            </div>
            <div class="form-row">
              <div class="field"><label for="cf-message">{t.contact.message} *</label><textarea id="cf-message" name="message" required placeholder={t.contact.messagePlaceholder}></textarea></div>
            </div>
            <button type="submit" class="btn btn-primary">{t.contact.send}</button>
            <div class="form-success" data-form-success>{t.contact.successMsg}</div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <script src="/scripts/contact.js" defer></script>
</BaseLayout>
