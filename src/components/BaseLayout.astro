---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import type { Locale } from '../lib/data';
import { i18n } from '../lib/data';
import { otherLocale } from '../lib/paths';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Path on this site (e.g. '/catalog.html'). Used for canonical + hreflang. */
  pathname: string;
  /** Equivalent path on the other locale (e.g. '/ru/catalog.html'). */
  altPathname: string;
  /** Optional JSON-LD structured data string. */
  schemaJson?: string;
}

const { locale, title, description, pathname, altPathname, schemaJson } = Astro.props;
const t = i18n[locale];
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = `${siteUrl}${pathname}`;
const altLocaleHref = `${siteUrl}${altPathname}`;
const altLang = otherLocale(locale);
const ogLocale = locale === 'ro' ? 'ro_RO' : 'ru_RU';
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#1f1d1a" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang={locale} href={canonical} />
  <link rel="alternate" hreflang={altLang} href={altLocaleHref} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:site_name" content="Promax Construct" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&display=swap" />
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}
</head>
<body>
  <a href="#main" class="skip-link">{t.common.skipToContent}</a>
  <Header locale={locale} altLocaleHref={altLocaleHref} />
  <slot />
  <Footer locale={locale} />
  <script src="/scripts/main.js" defer></script>
</body>
</html>
